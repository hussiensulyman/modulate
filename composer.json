{
  "name": "hussiensulyman/modulate",
  "description": "A modular monolith architecture toolkit for Laravel.",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.2",
    "illuminate/support": "^10.0|^11.0",
    "symfony/finder": "^6.0|^7.0"
  },
  "require-dev": {
    "orchestra/testbench": "^8.0|^9.0",
    "pestphp/pest": "^2.0|^3.0"
  },
  "autoload": {
    "psr-4": {
      "Modulate\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Modulate\\ModulateServiceProvider"
      ]
    }
  },
  "scripts": {
    "test": "pest",
    "test:ci": "pest --coverage-clover=coverage.xml",
    "lint": "pest --filter ViolationScanner"
  },
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  }
}
